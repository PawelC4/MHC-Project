# ═══════════════════════════════════════════════════════════
# Subway Quest — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to source control.
# ═══════════════════════════════════════════════════════════

# ─── Google Maps Platform ──────────────────────────────────
# Required for live turn-by-turn subway routing in lib/map.js.
# Enable: Directions API, Maps JavaScript API
# Restrict key to your domain in the Google Cloud Console.
# Docs: https://developers.google.com/maps/documentation/directions
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Exposed to the browser bundle (used in lib/map.js fetch call):
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Anthropic API ─────────────────────────────────────────
# Used SERVER-SIDE ONLY — never expose this in client JS.
# Route through an API Route Handler at /api/verify-photo.
# See lib/photo.js for the expected request/response contract.
# Docs: https://docs.anthropic.com/en/api/messages
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model for photo verification (vision-capable):
#   claude-opus-4-6       — highest accuracy, slower
#   claude-sonnet-4-6     — balanced (recommended)
#   claude-haiku-4-5-20251001 — fastest, lower cost
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
